# AI Provider Configuration

# =============================================================================
# OPTION 1: GitHub Models (Free - Good for Learning)
# =============================================================================
# Get your GitHub Personal Access Token at: https://github.com/settings/tokens
# No special scopes needed - just generate a token

AI_API_KEY=your_github_personal_access_token_here
AI_ENDPOINT=https://models.inference.ai.azure.com
AI_MODEL=gpt-4.1-mini #gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-ada-002

AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here

SERPAPI_KEY=your_serpapi_key_here